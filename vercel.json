{
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.mastersecurity.md" }],
      "destination": "https://mastersecurity.md/$1",
      "permanent": true
    }
  ]
}
